# Anthropic Admin API Key
# Get from: https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-xxxxx

# Prometheus URL (Railway 배포 후 설정)
# 설정 시 data source가 자동으로 prometheus로 전환됨
PROMETHEUS_URL=https://prometheus-production-xxxx.up.railway.app

# 데이터 소스 명시적 지정 (선택, 기본값: 자동감지)
# prometheus | admin-api | mock
# DATA_SOURCE=mock
